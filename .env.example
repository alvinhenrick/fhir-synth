# API Keys for LLM Providers
# Copy this file to .env and fill in your actual API keys

# OpenAI API Key (for GPT-4, GPT-3.5-turbo, etc.)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude models)
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# AWS Credentials (for Bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure OpenAI
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=2024-02-15-preview

# Other LLM Providers
# Add any other API keys needed for your LLM provider

# Optional: Default LLM Provider (if not specified in CLI)
# Valid values: mock, gpt-4, claude-3-opus, bedrock/anthropic.claude-v2, azure/gpt-4, etc.
# DEFAULT_LLM_PROVIDER=gpt-4

# ── Executor Backends (all powered by smolagents) ──────────────────────────

# All executor backends use smolagents under the hood.
# Select a backend with: fhir-synth generate ... --executor <backend>

# Local executor (default) — no extra config needed
# fhir-synth generate "5 patients" --executor local

# Docker executor — runs code in an isolated Docker container
# Requires: pip install "fhir-synth[docker]" and a running Docker daemon
# fhir-synth generate "5 patients" --executor docker

# E2B Cloud Sandbox — fully isolated micro-VMs
# Requires: pip install "fhir-synth[e2b]"
# Get your API key from: https://e2b.dev/dashboard
# E2B_API_KEY=e2b_...

# Blaxel Cloud Sandbox — managed serverless sandboxes
# Requires: pip install "fhir-synth[blaxel]"
# fhir-synth generate "5 patients" --executor blaxel

